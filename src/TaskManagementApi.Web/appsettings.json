{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=TaskDb;Username=postgres;Password=password"
  },
  "Keycloak": {
    "AuthServerUrl": "https://your-keycloak-server",
    "Realm": "your-realm",
    "ClientId": "your-client-id",
    "ClientSecret": "your-client-secret"
  },
  "App": {
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000"
      ],
      "AllowedMethods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "OPTIONS"
      ]
    }
  }
}

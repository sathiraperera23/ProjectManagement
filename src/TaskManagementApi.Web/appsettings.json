{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=TaskDb;Username=postgres;Password=password"
  },
  "Keycloak": {
    "AuthServerUrl": "https://your-keycloak-server",
    "Realm": "your-realm",
    "ClientId": "your-client-id",
    "ClientSecret": "your-client-secret"
  },
  "App": {
    "Url": "http://localhost:3000",
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000"
      ],
      "AllowedMethods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "OPTIONS"
      ]
    }
  },
  "SendGrid": {
    "ApiKey": "SG.xxx"
  },
  "Twilio": {
    "AccountSid": "ACxxx",
    "AuthToken": "xxx",
    "FromNumber": "+123456789"
  },
  "Org": {
    "SmsQuietHours": {
      "Start": "21:00",
      "End": "07:00"
    }
  },
  "BugDetection": {
    "SimilarityThreshold": "0.8"
  },
  "Email": {
    "Host": "your-smtp-host",
    "Port": 587,
    "Username": "your-email@domain.com",
    "Password": "your-password",
    "FromAddress": "your-email@domain.com",
    "FromDisplayName": "Task Management System",
    "EnableSsl": false,
    "StartTls": true,
    "ConnectionTimeout": 5000
  },
  "Sms": {
    "CommonModuleUrl": "http://your-common-module-url",
    "Endpoint": "/send-sms",
    "Enabled": true
  },
  "Otp": {
    "SmsExpirationSeconds": 300
  }
}
